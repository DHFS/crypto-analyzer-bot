# ==========================================
# Crypto Analyzer Bot - 腾讯云部署环境变量配置
# 复制此文件为 .env 并填入实际值
# ==========================================

# ------------------- Discord Bot -------------------
# 从 Discord Developer Portal 获取
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ------------------- Binance API -------------------
# 从 Binance API 管理页面获取 (只需读取权限)
# https://www.binance.com/cn/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ------------------- AI 模型 API -------------------
# 主用：Moonshot (Kimi) API
# https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 备用：OpenAI API (可选)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# 备用：Google Gemini API (可选)
# https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# 备用：Anthropic Claude API (可选)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------- Bot 配置 -------------------
# 默认 AI 模型: kimi / gemini / gpt / claude
DEFAULT_AI_MODEL=kimi

# 代理设置 (中国大陆服务器可能需要)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ------------------- 高级配置 -------------------
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 数据库路径 (默认: data/trades.db)
# DATABASE_PATH=data/trades.db

# 预警检查间隔 (分钟)
ALERT_CHECK_INTERVAL=5

# 订单追踪检查间隔 (分钟)
TRACKER_CHECK_INTERVAL=5
